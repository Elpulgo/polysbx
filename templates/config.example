# polysbx config — generated by `psb init`. Sourced as shell; KEY=VALUE only.
# Lives at ~/.config/polysbx/config. Secrets go in the sibling secrets.env (0600).

BACKEND=docker                 # docker | sbx (beta) | msbx (beta)
AUTH_MODE=subscription         # subscription | apikey | token
LANGUAGES=""                   # space-separated subset of: dotnet go python rust
CONFIG_DIR="$HOME/.claude"     # your Claude config dir (skills/agents/commands/hooks/rules/settings.json)

ADO_ENABLED=0                  # 1 → bundle azure-cli, pass AZURE_DEVOPS_EXT_PAT
GH_ENABLED=0                   # 1 → bundle gh, pass GITHUB_TOKEN

DENY_MERGE=0                   # 1 → union packaged deny-list into your settings.json (into a polysbx copy)
SETTINGS_EXAMPLE=0             # 1 → install templates/settings.example.json when you have none

IMAGE_TAG=polysbx:latest
MEMORY=8g
CPUS=4
PIDS=256
NET_MODE=open                  # open | allowlist (allowlist applies to sbx/msbx)
